font-family = JetBrainsMono Nerd Font
font-size = 13 

# One dark theme but fig the auto suggestion not visible
#https://github.com/ghostty-org/ghostty/issues/3450
theme = OneHalfDark
palette = 0=#707682
palette = 8=#707682
# Change to match the Darkder variation from nvim-onedark
# https://github.com/navarasu/onedark.nvim/blob/master/lua/onedark/palette.lua
background = 1f2329
#background = 000000

shell-integration-features = no-cursor,sudo,no-title
cursor-style = block
cursor-color = f4b278
cursor-opacity = 0.7
cursor-style-blink = false

background-opacity = 0.9
unfocused-split-opacity = 0.8

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

window-padding-balance = true 
window-save-state = always
#foreground = d4be98

# other
#copy-on-select = clipboard
shell-integration = zsh
window-decoration = false

window-padding-x = 15
window-padding-y = 5
window-padding-color = extend

clipboard-paste-protection = false
confirm-close-surface = false

#fix erros when ssh to bandit server 
term=xterm-256color 
